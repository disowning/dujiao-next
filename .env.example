# 对外只由 1Panel 网站反向代理访问此本机端口。
HOST_PORT=18080
TZ=Asia/Shanghai
APP_VERSION=self-hosted

# 使用 `openssl rand -hex 32` 分别生成三个不同的值。
APP_SECRET_KEY=
JWT_SECRET=
USER_JWT_SECRET=

# 后台地址必须以 / 开头，建议使用不易猜到的路径。
WEB_ADMIN_PATH=

# 仅首次启动、数据库内没有管理员时用于创建管理员。
DJ_DEFAULT_ADMIN_USERNAME=admin
DJ_DEFAULT_ADMIN_PASSWORD=
